APP_NAME="NDT Web Application"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_TIMEZONE=UTC
APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_DAILY_DAYS=14

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=ndt
DB_USERNAME=ndt
DB_PASSWORD=ndt

BROADCAST_CONNECTION=log
CACHE_STORE=redis
FILESYSTEM_DISK=private
QUEUE_CONNECTION=redis
SESSION_DRIVER=database
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@example.test"
MAIL_FROM_NAME="${APP_NAME}"

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:5173
VITE_APP_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

BACKUP_ROOT=storage/app/backups
BACKUP_RETENTION_DAYS=7
BACKUP_MYSQL_DATABASE=${DB_DATABASE}
BACKUP_MYSQL_HOST=${DB_HOST}
BACKUP_MYSQL_PORT=${DB_PORT}
BACKUP_MYSQL_USER=${DB_USERNAME}
BACKUP_MYSQL_PASSWORD=${DB_PASSWORD}
BACKUP_STORAGE_PATH=storage/app/private
HEALTH_CHECK_STORAGE_DISK=private
HEALTH_CHECK_REDIS_CONNECTION=default
TEMPORARY_FILE_CLEANUP_HOURS=24
